# ODPT（公共交通オープンデータセンター）の consumerKey
# https://developer.odpt.org/ で無料登録して取得
ODPT_TOKEN=ここにODPTのトークン

# X(API) の認証情報（developer.x.com で取得）
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# 現在地入力・経路案内ページ（PWA）のURL。投稿リンク先になる
PWA_BASE_URL=https://あなたのユーザー名.github.io/furikae-navi/

# 動作確認用: true にすると投稿せず内容を表示するだけ
DRY_RUN=true
